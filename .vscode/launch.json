{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python: Run Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false,
            "stopOnEntry": false
        },
        {
            "name": "Python: Train SHS-Net",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--gpu=0",
                "--mode=train",
                "--data_set=PCPNet"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "Python: Train SHS-Net (Direct)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--dataset_root=/home/hbcho/NeuralGF/dataset",
                "--trainset_list=trainingset_whitenoise",
                "--patch_size=700",
                "--batch_size=145",
                "--sample_size=1200",
                "--encode_knn=16",
                "--lr=0.0009",
                "--resume="
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "justMyCode": false
        },
        {
            "name": "Python: Test SHS-Net - PCPNet",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--gpu=0",
                "--mode=test",
                "--data_set=PCPNet",
                "--ckpt_dirs=001",
                "--ckpt_iters=800"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "Python: Test SHS-Net - PCPNet (Direct)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--gpu=0",
                "--dataset_root=/home/hbcho/NeuralGF/dataset",
                "--data_set=PCPNet",
                "--log_root=./log",
                "--ckpt_dirs=001",
                "--ckpt_iters=800",
                "--patch_size=700",
                "--batch_size=700",
                "--sample_size=1200",
                "--encode_knn=16",
                "--save_pn=True",
                "--save_xyz=True",
                "--save_obj=True",
                "--sparse_patches=False",
                "--tag=",
                "--testset_list=testset_PCPNet",
                "--eval_list",
                "testset_no_noise",
                "testset_low_noise",
                "testset_med_noise",
                "testset_high_noise",
                "testset_vardensity_striped",
                "testset_vardensity_gradient"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        
        
    ]
}