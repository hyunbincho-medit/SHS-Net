{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python: Run Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false,
            "stopOnEntry": false
        },
        {
            "name": "Python: Train SHS-Net",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--gpu=0",
                "--mode=train",
                "--data_set=PCPNet"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "Python: Train SHS-Net (Direct)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--dataset_root=/home/hbcho/NeuralGF/dataset",
                "--trainset_list=trainingset_whitenoise",
                "--patch_size=700",
                "--batch_size=145",
                "--sample_size=1200",
                "--encode_knn=16",
                "--lr=0.0009",
                "--resume="
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "justMyCode": false
        },
        {
            "name": "Python: Test NeuralGF - PCPNet",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train_test.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--mode=test",
                "--gpu=0",
                "--data_set=PCPNet",
                "--ckpt_dir=231007_140818_PCPNet",
                "--ckpt_iter=20000",
                "--dataset_root=./dataset",
                "--save_normal_npy=False",
                "--save_normal_xyz=True",
                "--save_mesh=True"

            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "Python: Test NeuralGF - FamousShape",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train_test.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--mode=test",
                "--gpu=0",
                "--data_set=FamousShape",
                "--ckpt_dir=231017_211111_FamousShape",
                "--ckpt_iter=20000",
                "--dataset_root=./dataset",
                "--save_normal_npy=False",
                "--save_normal_xyz=True",
                "--save_mesh=True"

            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        }
    ]
}